---
import { FeaturedProjects } from "@components/features/featured-projects";
import { PageHeader } from "@components/features/page-header";
import { ProjectsCategory } from "@components/features/projects-category";
import { StatsGrid } from "@components/features/stats-grid";
import { TechStack } from "@components/features/tech-stack";
import MainGridLayout from "@layouts/MainGridLayout.astro";

import { siteConfig } from "../config";
import { UNCATEGORIZED } from "../constants/constants";
import {
	getAllTechStack,
	getFeaturedProjects,
	getProjectsByCategory,
	getProjectStats,
	projectsData,
} from "../data/projects";
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";

if (!siteConfig.featurePages.projects) {
	return Astro.redirect("/404/");
}

const stats = getProjectStats();
const featuredProjects = getFeaturedProjects();
const allTechStack = getAllTechStack();

const categories = [...new Set(projectsData.map((project) => project.category))];

const projectsByCategory = categories.reduce(
	(acc, category) => {
		acc[category] = getProjectsByCategory(category);
		return acc;
	},
	{} as Record<string, typeof projectsData>,
);

const getCategoryText = (category: string) => {
	switch (category) {
		case "web":
			return i18n(I18nKey.projectsWeb);
		case "mobile":
			return i18n(I18nKey.projectsMobile);
		case "desktop":
			return i18n(I18nKey.projectsDesktop);
		case "other":
			return i18n(I18nKey.projectsOther);
		case UNCATEGORIZED:
			return i18n(I18nKey.uncategorized);
		default:
			return category;
	}
};

const title = i18n(I18nKey.projects);
const subtitle = i18n(I18nKey.projectsSubtitle);

const statItems = [
	{ title: i18n(I18nKey.projectsTotal), value: stats.total.toString(), color: "#3B82F6" },
	{ title: i18n(I18nKey.projectsCompleted), value: stats.byStatus.completed.toString(), color: "#22C55E" },
	{ title: i18n(I18nKey.projectsInProgress), value: stats.byStatus.inProgress.toString(), color: "#F59E0B" },
	{ title: i18n(I18nKey.projectsTechStack), value: allTechStack.length.toString(), color: "#A855F7" },
];
---

<MainGridLayout title={title} description={subtitle}>
	<script>
		import("../scripts/right-sidebar-layout.js");
		import { loadIconify } from "../utils/icon-loader";

		loadIconify().catch((error) => {
			console.error("Failed to load Iconify:", error);
		});
	</script>

	<div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
		<div class="card-base z-10 px-9 py-6 relative w-full">
			<PageHeader title={title} subtitle={subtitle} />

			<StatsGrid stats={statItems} columns={4} />

			{featuredProjects.length > 0 && (
				<FeaturedProjects
					class="mb-8"
					title={i18n(I18nKey.projectsFeatured)}
					projects={featuredProjects}
				/>
			)}

			<div class="space-y-8">
				{categories.map((category) => {
					const categoryProjects = projectsByCategory[category];
					if (categoryProjects.length === 0) {return null;}

					return (
						<ProjectsCategory
							category={category}
							categoryText={getCategoryText(category)}
							projects={categoryProjects}
						/>
					);
				})}
			</div>

			<TechStack
				class="mt-12 pt-8 border-t border-black/10 dark:border-white/10"
				title={i18n(I18nKey.projectsTechStack)}
				techStack={allTechStack}
			/>
		</div>
	</div>
</MainGridLayout>
